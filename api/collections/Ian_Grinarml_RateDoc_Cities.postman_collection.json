{
  "info": {
    "name": "RateDoc Cities API Tests (Full CRUD)",
    "_postman_id": "99999999-8888-7777-6666-555555555555",
    "description": "Full CRUD API tests for Cities (Create, Read, Update, Delete)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Countries",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/countries",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "countries"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "const items = Array.isArray(json) ? json : (json.items || []);",
              "",
              "pm.test(\"Countries list exists\", function () {",
              "  pm.expect(items).to.be.an(\"array\");",
              "});",
              "",
              "if (items.length > 0) {",
              "  pm.environment.set(\"countryId\", items[0].id || items[0]._id);",
              "}"
            ]
          }
        }
      ]
    },

    {
      "name": "Create City",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test City\",\n  \"country_id\": {{countryId}}\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/cities",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "cities"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 or 201\", function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "if (pm.response.code !== 200 && pm.response.code !== 201) {",
              "  console.log(\"Create City FAILED:\", pm.response.text());",
              "  postman.setNextRequest(null);",
              "  return;",
              "}",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test(\"City ID exists\", function () {",
              "  pm.expect(json.id).to.exist;",
              "});",
              "",
              "pm.environment.set(\"cityId\", json.id);"
            ]
          }
        }
      ]
    },

    {
      "name": "Get City by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/cities/{{cityId}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "cities", "{{cityId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test(\"City ID matches\", function () {",
              "  pm.expect(json.id).to.eql(pm.environment.get(\"cityId\"));",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "Update City",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Updated Test City\",\n  \"country_id\": {{countryId}}\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/cities/{{cityId}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "cities", "{{cityId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test(\"City updated\", function () {",
              "  pm.expect(json.name).to.eql(\"Updated Test City\");",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "Delete City",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/cities/{{cityId}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "cities", "{{cityId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 or 204\", function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "Verify City Deleted",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/cities/{{cityId}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "cities", "{{cityId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"City no longer exists\", function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([404, 410]);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}