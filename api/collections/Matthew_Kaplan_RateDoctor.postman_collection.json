    {
      "name": "User Profile Info for Logged In User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () \r",
              "{\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "let jsonData = pm.response.json();\r",
              "//Checks that all user info is a string\r",
              "pm.test(\"User info found and is string\", function () \r",
              "{\r",
              "    pm.expect(jsonData.id).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.email).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.name).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.role).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.created_at).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.updated_at).to.be.a(\"string\");\r",
              "});\r",
              "//checks that user email matches\r",
              "pm.test(\"User email matches, correct user info found\", function()\r",
              "{\r",
              "    pm.expect(jsonData.email).to.equal(pm.environment.get(\"userEmail\"));\r",
              "});\r",
              "//Checks profile for URL or null\r",
              "//Separate because profile picture is optional\r",
              "pm.test(\"Optional Profile picture URL null or string\", function () \r",
              "{\r",
              "    if (jsonData.profile_picture_url !== null) \r",
              "    {\r",
              "        pm.expect(jsonData.profile_picture_url).to.be.a(\"string\");\r",
              "    }\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
