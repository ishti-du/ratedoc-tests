  "item": [
    {
      "name": "Create User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () \r",
              "{\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "let jsonData = pm.response.json();\r",
              "let newEmail = pm.environment.get(\"newEmail\")\r",
              "let newName = pm.environment.get(\"newName\")\r",
              "let newPassword = pm.environment.get(\"newPassword\")\r",
              "pm.test(\"User info matches\", function()\r",
              "{\r",
              "    pm.expect(jsonData.email).to.eql(newEmail);\r",
              "    pm.expect(pm.response.json().name).to.eql(newName);\r",
              "});\r",
              "if (jsonData.email === newEmail)\r",
              "{\r",
              "    pm.environment.set(\"userEmail\", newEmail);\r",
              "};\r",
              "if (jsonData.name === newName)\r",
              "{\r",
              "    pm.environment.set(\"userName\", newName);\r",
              "};\r",
              "pm.environment.set(\"userPassword\", newPassword);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var next = Date.now();\r",
              "var newEmail = \"test_\" + next + \"@example.com\";\r",
              "var newName = \"test_\" + next;\r",
              "var newPassword = \"test_\" + next + \"!@#\";\r",
              "pm.environment.set(\"newEmail\", newEmail);\r",
              "pm.environment.set(\"newName\", newName);\r",
              "pm.environment.set(\"newPassword\", newPassword);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
