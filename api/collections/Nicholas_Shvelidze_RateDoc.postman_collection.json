              "",
              "let json = pm.response.json();",
              "let center = json.data || json;",
              "let id = center.id || center._id || center.diagnostic_center_id;",
              "",
              "pm.test('Created diagnostic center has ID', function () {",
              "    pm.expect(id).to.exist;",
              "});",
              "",
              "if (id) {",
              "    pm.environment.set('diagnosticCenterId', id);",
              "}"
            ]
          }
        }
