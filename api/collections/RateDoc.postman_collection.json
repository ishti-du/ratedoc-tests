          "raw": "{\n  \"name\": \"Best General Hospital\",\n  \"address\": \"Islampur, Majortila, Sylhet\",\n  \"city_id\": 1,\n  \"country_id\": 1\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/hospitals/{{hospital_slug}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "hospitals", "{{hospital_slug}}"]
