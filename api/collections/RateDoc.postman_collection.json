    {
      "name": "reject hospital - should work",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// admin rejects a hospital, status should change to rejected",
              "pm.test('status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('hospital status is now rejected', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql('rejected');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "{{base_url}}/api/v1/hospitals/{{hospital_slug}}/reject",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "hospitals", "{{hospital_slug}}", "reject"]
        }
      }
