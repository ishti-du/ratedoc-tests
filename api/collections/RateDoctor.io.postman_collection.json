  "item": [
    {
      "name": "Authenticate Admin",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const suffix = Date.now().toString();",
              "pm.environment.set('hospitalName', `Copilot Test Hospital ${suffix}`);",
              "pm.environment.set('updatedHospitalName', `Copilot Updated Hospital ${suffix}`);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response contains access token', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('access_token');",
              "    pm.expect(json.access_token).to.be.a('string').and.not.empty;",
              "    pm.environment.set('adminToken', json.access_token);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"{{adminUsername}}\",\"password\":\"{{adminPassword}}\"}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        },
        "description": "Logs in with JSON credentials and stores the admin access token for the rest of the collection."
      },
      "response": []
    },
