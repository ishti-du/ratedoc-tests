                      "})",
                      "",
                      "pm.test('Response has items array', function () {",
                      "    const json = pm.response.json();",
                      "    pm.expect(json).to.have.property('items');",
                      "    pm.expect(json.items).to.be.an('array');",
                      "    pm.expect(json).to.have.property('total');",
                      "})",
                      "",
                      "pm.test('Each hospital has required fields', function () {",
                      "    const json = pm.response.json();",
                      "    if (json.items.length > 0) {",
                      "        json.items.forEach(function (hospital) {",
                      "            pm.expect(hospital).to.have.property('id');",
                      "            pm.expect(hospital).to.have.property('name');",
                      "        });",
                      "    }",
                      "})",
                      "",
                      "pm.test('Response time is less than 2000ms', function () {",
