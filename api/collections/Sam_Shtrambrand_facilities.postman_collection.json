      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Delete Facility returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Delete Facility returns a success message', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property('message').that.is.a('string');",
              "  pm.expect(body.message.toLowerCase()).to.include('deleted');",
              "});",
              "",
              "pm.collectionVariables.unset('facility_id');"
            ]
