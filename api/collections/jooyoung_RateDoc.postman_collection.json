{
  "info": {
    "name": "jooyoung_RateDoc API Tests",
    "description": "API tests for Jooyoung's assigned RateDoctor delete endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login - Get Auth Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/auth/token",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "auth", "token"]
        },
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "username",
              "value": "{{email}}"
            },
            {
              "key": "password",
              "value": "{{password}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const response = pm.response.json();",
              "pm.environment.set('token', response.access_token);",
              "",
              "pm.test('Access token is returned and saved', function () {",
              "    pm.expect(response.access_token).to.exist;",
              "    pm.expect(pm.environment.get('token')).to.exist;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete Doctor",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/admin/doctors/{{doctor_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "admin", "doctors", "{{doctor_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Delete doctor returns valid response', function () {",
              "    pm.expect([200, 401, 404]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete Hospital",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/admin/hospitals/{{hospital_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "admin", "hospitals", "{{hospital_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Delete hospital returns valid response', function () {",
              "    pm.expect([200, 401, 404]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete Department",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/departments/{{department_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "departments", "{{department_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Delete department returns valid response', function () {",
              "    pm.expect([200, 401, 404]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}