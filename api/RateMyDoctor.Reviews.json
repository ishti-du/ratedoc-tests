  },
  "item": [
    {
      "name": "Auth Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login successful', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const response = pm.response.json();",
              "pm.collectionVariables.set('accessToken', response.access_token);",
              "console.log('Token saved:', response.access_token ? 'YES' : 'MISSING');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"avik@example.com\",\n  \"password\": \"password123\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseURL}}/api/v1/auth/login",
          "host": ["{{baseURL}}"],
          "path": ["api", "v1", "auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "Create Review",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const uniqueComment = 'TEST_REVIEW_' + Date.now();",
              "pm.collectionVariables.set('test_comment', uniqueComment);",
              "console.log('Using comment:', uniqueComment);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Review created successfully', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "console.log('Create response:', pm.response.json());"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
        },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"provider_type\": \"doctor\",\n  \"provider_slug\": \"dr-md-khaled-mohsin-001efb08\",\n  \"visit_date\": \"2026-04-28T17:40:22.106Z\",\n  \"rating\": 1,\n  \"comment\": \"{{test_comment}}\",\n  \"is_anonymous\": false,\n  \"extra_info\": {\n    \"anonymous_tag\": \"TJY8\",\n    \"question_scores\": {\n      \"listens_carefully\": 1,\n      \"staff_cooperative\": 1,\n      \"explains_treatment_options\": 1,\n      \"prescribes_effective_treatment\": 1\n    },\n    \"wait_time_bucket\": \"gt_60\"\n  }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseURL}}/api/v1/reviews",
          "host": ["{{baseURL}}"],
          "path": ["api", "v1", "reviews"]
        }
      },
      "response": []
    },
    {
      "name": "List Reviews",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('List reviews returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "",
              "// Response shape is {items: [...]}", 
              "const reviews = body.items || [];",
              "",
              "const testComment = pm.collectionVariables.get('test_comment');",
              "console.log('Looking for comment:', testComment);",
              "console.log('Total reviews in list:', reviews.length);",
              "",
              "const createdReview = reviews.find(r => r.comment === testComment);",
              "",
              "pm.test('Created review found in list', function () {",
              "    pm.expect(createdReview, 'Could not find review with comment: ' + testComment).to.not.be.undefined;",
              "});",
              "",
              "if (createdReview) {",
              "    const reviewId = createdReview.id;",
              "    pm.collectionVariables.set('review_id', reviewId);",
              "    console.log('Saved review_id:', reviewId);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseURL}}/api/v1/reviews",
          "host": ["{{baseURL}}"],
          "path": ["api", "v1", "reviews"]
        }
      },
      "response": []
    },
    {
      "name": "Get Review",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Get review returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const review = pm.response.json();",
              "",
              "pm.test('Returns correct review ID', function () {",
              "    const reviewId = pm.collectionVariables.get('review_id');",
              "    pm.expect(String(review.id)).to.equal(String(reviewId));",
              "});",
              "",
              "pm.test('Review has correct comment', function () {",
              "    pm.expect(review.comment).to.equal(pm.collectionVariables.get('test_comment'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseURL}}/api/v1/reviews/{{review_id}}",
          "host": ["{{baseURL}}"],
          "path": ["api", "v1", "reviews", "{{review_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "Update Review",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Update review returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const review = pm.response.json();",
              "",
              "pm.test('Comment was updated', function () {",
              "    pm.expect(review.comment).to.equal('UPDATED TEST COMMENT');",
              "});",
              "",
              "console.log('Updated review:', review);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
        },
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"provider_type\": \"doctor\",\n  \"provider_slug\": \"dr-md-khaled-mohsin-001efb08\",\n  \"visit_date\": \"2026-04-28T17:40:22.106Z\",\n  \"rating\": 1,\n  \"comment\": \"UPDATED TEST COMMENT\",\n  \"is_anonymous\": false,\n  \"extra_info\": {\n    \"anonymous_tag\": \"TJY8\",\n    \"question_scores\": {\n      \"listens_carefully\": 1,\n      \"staff_cooperative\": 1,\n      \"explains_treatment_options\": 1,\n      \"prescribes_effective_treatment\": 1\n    },\n    \"wait_time_bucket\": \"gt_60\"\n  }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseURL}}/api/v1/reviews/{{review_id}}",
          "host": ["{{baseURL}}"],
          "path": ["api", "v1", "reviews", "{{review_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "Delete Review",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Delete review returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "console.log('Deleted review_id:', pm.collectionVariables.get('review_id'));",
              "",
              "pm.collectionVariables.unset('review_id');",
              "pm.collectionVariables.unset('test_comment');",
              "pm.collectionVariables.unset('accessToken');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
