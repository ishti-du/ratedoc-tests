    {
      "name": "Auth Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse the JSON response body",
              "let jsonData = pm.response.json();",
              "",
              "// Check and set the access token (fixed the typo here)",
              "if (jsonData.access_token) {",
              "    pm.globals.set(\"access_token\", jsonData.access_token);",
              "    console.log(\"Access token successfully saved to globals.\");",
              "} else {",
              "    console.warn(\"Access token not found in the response payload.\");",
              "}",
              "",
              "// Check and set the refresh token",
              "if (jsonData.refresh_token) {",
              "    pm.globals.set(\"refresh_token\", jsonData.refresh_token);",
              "    console.log(\"Refresh token successfully saved to globals.\");",
              "}"
            ],
