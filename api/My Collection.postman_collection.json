    {
      "name": "Update Department",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Verify the status code is 200 OK",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// 2. Verify the response contains the updated name",
              "pm.test(\"Department name updated successfully\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.name).to.eql(\"Updated Cardiology Unit\");",
              "});",
              "",
              "// 3. Verify the ID matches what we updated",
              "pm.test(\"Correct Department ID returned\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.id).to.eql(10);",
              "});",
              "",
              "// 4. Check that the updated_at field is recent",
              "pm.test(\"Update timestamp is current\", function () {",
              "    const jsonData = pm.response.json();",
              "    // This checks if the date string includes today's date",
              "    pm.expect(jsonData.updated_at).to.include(\"2026-04-28\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
