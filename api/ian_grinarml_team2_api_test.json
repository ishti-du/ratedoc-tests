{
  "info": {
    "name": "RateDoc Cities API Tests (Stable)",
    "_postman_id": "99999999-8888-7777-6666-555555555555",
    "description": "API tests for Cities",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Countries",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/countries",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "countries"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "const items = Array.isArray(json) ? json : (json.items || []);",
              "",
              "pm.test(\"Countries list exists\", function () {",
              "    pm.expect(items).to.be.an(\"array\");",
              "});",
              "",
              "if (items.length > 0) {",
              "    pm.environment.set(\"countryId\", items[0].id || items[0]._id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Cities",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/cities",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "cities"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "const items = Array.isArray(json) ? json : (json.items || []);",
              "",
              "pm.test(\"Cities list exists\", function () {",
              "    pm.expect(items).to.be.an(\"array\");",
              "});",
              "",
              "if (items.length > 0) {",
              "    pm.environment.set(\"cityId\", items[0].id || items[0]._id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get City by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/cities/{{cityId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "cities", "{{cityId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is valid\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
              "});",
              "",
              "if (pm.response.code === 200) {",
              "    pm.test(\"Response is JSON\", function () {",
              "        pm.response.to.be.json;",
              "    });",
              "",
              "    const json = pm.response.json();",
              "",
              "    pm.test(\"City object exists\", function () {",
              "        pm.expect(json).to.exist;",
              "    });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Invalid City ID Test",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/cities/999999999",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "cities", "999999999"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Invalid ID returns error\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([404, 422]);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
